# Resend API key for sending transactional emails via the contact form.
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives new contact form submissions.
CONTACT_EMAIL_TO=support@packisher.com

# The verified sender email address in Resend (must match a verified domain).
CONTACT_EMAIL_FROM=support@packisher.com

# The canonical public URL of the site (no trailing slash).
# Used for sitemap, OG tags, and canonical URLs.
NEXT_PUBLIC_SITE_URL=https://packisher.com
