# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (anything except the example template)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# secrets / credentials (defence-in-depth)
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
secrets.json
credentials.json
service-account*.json

# local archives / scratch (never commit these)
*.zip
*.tar
*.tar.gz
*.tgz

# editor / agent state
.claude/
.cursor/
.idea/
.vscode/

# OS junk
.DS_Store
Thumbs.db
